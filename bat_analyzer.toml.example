# PE Analyzer Configuration
# Copy to bat_analyzer.toml or ~/.config/bat_analyzer/config.toml

[paths]
capa_rules = "/tmp/capa-rules"
# ghidra_headless = "/opt/homebrew/opt/ghidra/libexec/support/analyzeHeadless"
# yara_extra_dirs = ["/path/to/custom/rules"]

[features]
capa = true
yara = true
# decompile = "both"  # "r2", "ghidra", or "both"

[output]
no_color = false
quiet = false
json = false

[llm]
# url = "http://localhost:11434"   # Ollama default
# model = "llama3"                  # or any Ollama model: mistral, codellama, etc.
# report = false                    # set true to always generate LLM reports
